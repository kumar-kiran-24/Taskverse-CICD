[Unit]
Description=Taskverse College Service
After=network.target

[Service]
WorkingDirectory=/opt/taskverse/college

ExecStart=/usr/bin/dotnet /opt/taskverse/college/Taskverse.API.College.Service.dll

Restart=always
RestartSec=10

KillSignal=SIGINT

SyslogIdentifier=taskverse-college

User=root

Environment=ASPNETCORE_ENVIRONMENT=Production
Environment=ASPNETCORE_URLS=http://0.0.0.0:5002

[Install]
WantedBy=multi-user.target