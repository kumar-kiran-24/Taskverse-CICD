[Unit]
Description=Taskverse Auth Service
After=network.target

[Service]
WorkingDirectory=/opt/taskverse/auth

ExecStart=/usr/bin/dotnet /opt/taskverse/auth/Taskverse.API.Auth.Service.dll

Restart=always
RestartSec=10

KillSignal=SIGINT

SyslogIdentifier=taskverse-auth

User=root

Environment=ASPNETCORE_ENVIRONMENT=Production
Environment=ASPNETCORE_URLS=http://0.0.0.0:5001

[Install]
WantedBy=multi-user.target