[Unit]
Description=Taskverse Reports Service
After=network.target

[Service]
WorkingDirectory=/opt/taskverse/reports

ExecStart=/usr/bin/dotnet /opt/taskverse/reports/Taskverse.API.Reports.Service.dll

Restart=always
RestartSec=10

KillSignal=SIGINT

SyslogIdentifier=taskverse-reports

User=root

Environment=ASPNETCORE_ENVIRONMENT=Production
Environment=ASPNETCORE_URLS=http://0.0.0.0:5005

[Install]
WantedBy=multi-user.target