[Unit]
Description=Taskverse Proctor Service
After=network.target

[Service]
WorkingDirectory=/opt/taskverse/proctor

ExecStart=/usr/bin/dotnet /opt/taskverse/proctor/Taskverse.API.Proctor.Service.dll

Restart=always
RestartSec=10

KillSignal=SIGINT

SyslogIdentifier=taskverse-proctor

User=root

Environment=ASPNETCORE_ENVIRONMENT=Production
Environment=ASPNETCORE_URLS=http://0.0.0.0:5006

[Install]
WantedBy=multi-user.target