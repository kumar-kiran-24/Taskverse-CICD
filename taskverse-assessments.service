[Unit]
Description=Taskverse Assessments Service
After=network.target

[Service]
WorkingDirectory=/opt/taskverse/assessments

ExecStart=/usr/bin/dotnet /opt/taskverse/assessments/Taskverse.API.Assessments.Service.dll

Restart=always
RestartSec=10

KillSignal=SIGINT

SyslogIdentifier=taskverse-assessments

User=root

Environment=ASPNETCORE_ENVIRONMENT=Production
Environment=ASPNETCORE_URLS=http://0.0.0.0:5004

[Install]
WantedBy=multi-user.target