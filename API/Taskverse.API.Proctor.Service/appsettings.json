{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "TaskverseDb": "Host=xxx;Port=5432;Database=xxx;Username=xxx;Password=xxx;SSL Mode=Require;Trust Server Certificate=true"
  },

  "Proctoring": {
    "Enabled": true,
    "OverallViolations": {
      "Enabled": true,
      "AutoSubmitAtCount": 10,
      "WarningMessage": "The maximum of 3 proctoring violations has been reached. Your assessment will be submitted automatically.",
      "LockAttemptOnLimitExceeded": false,
      "AutoSubmitOnLimitExceeded": true
    },

    "Fullscreen": {
      "Required": true,
      "MaxExitsAllowed": 2,
      "WarningMessage": "Fullscreen mode is required during the assessment.",
      "LockAttemptOnLimitExceeded": true,
      "AutoSubmitOnLimitExceeded": true
    },

    "TabSwitching": {
      "DetectionEnabled": true,
      "MaxSwitchesAllowed": 2,
      "WarningMessage": "Switching tabs or leaving the assessment window is not allowed.",
      "LockAttemptOnLimitExceeded": true,
      "AutoSubmitOnLimitExceeded": true
    },

    "Clipboard": {
      "DisableCopy": true,
      "DisablePaste": true,
      "DisableCut": true,
      "MaxCopyAttemptsAllowed": 0,
      "MaxPasteAttemptsAllowed": 0,
      "MaxCutAttemptsAllowed": 0,
      "WarningMessage": "Copy, paste, and cut actions are disabled during the assessment.",
      "LockAttemptOnLimitExceeded": false,
      "AutoSubmitOnLimitExceeded": false
    },

    "ContextMenu": {
      "Disabled": true,
      "MaxAttemptsAllowed": 3,
      "WarningMessage": "Right-click is disabled during the assessment.",
      "LockAttemptOnLimitExceeded": false,
      "AutoSubmitOnLimitExceeded": false
    },

    "KeyboardShortcuts": {
      "Disabled": true,
      "MaxBlockedShortcutAttemptsAllowed": 5,
      "WarningMessage": "This keyboard shortcut is disabled during the assessment.",
      "LockAttemptOnLimitExceeded": false,
      "AutoSubmitOnLimitExceeded": false,

      "BlockedKeys": [
        "F5",
        "F12",
        "Escape"
      ],

      "BlockedCombinations": [
        "Ctrl+C",
        "Ctrl+V",
        "Ctrl+X",
        "Ctrl+A",
        "Ctrl+F",
        "Ctrl+P",
        "Ctrl+S",
        "Ctrl+U",
        "Ctrl+R",
        "Ctrl+T",
        "Ctrl+N",
        "Ctrl+W",

        "Ctrl+Shift+I",
        "Ctrl+Shift+J",
        "Ctrl+Shift+C",

        "Meta+C",
        "Meta+V",
        "Meta+X",
        "Meta+A",
        "Meta+F",
        "Meta+P",
        "Meta+S",
        "Meta+R",
        "Meta+T",
        "Meta+N",
        "Meta+W",

        "Meta+Alt+I",
        "Meta+Alt+J",
        "Meta+Alt+C"
      ]
    },

    "DevTools": {
      "DetectionEnabled": true,
      "BlockCommonShortcuts": true,
      "DetectionIntervalSeconds": 3,
      "ViewportDifferenceThresholdPixels": 160,
      "MaxDetectionsAllowed": 1,
      "WarningMessage": "Developer tools are not allowed during the assessment.",
      "LockAttemptOnLimitExceeded": true,
      "AutoSubmitOnLimitExceeded": true
    },

    "Network": {
      "TrackDisconnects": true,
      "MaxDisconnectsAllowed": 3,
      "MaxOfflineDurationSeconds": 60,
      "WarningMessage": "Network connection lost. Please reconnect to continue.",
      "LockAttemptOnLimitExceeded": false,
      "AutoSubmitOnLimitExceeded": false
    },

    "Warnings": {
      "ShowCandidateWarnings": true,
      "ShowViolationCount": true,
      "RequireAcknowledgement": true,
      "DefaultWarningDurationSeconds": 5
    },

    "RiskScoring": {
      "Enabled": true,

      "Weights": {
        "TabSwitch": 20,
        "FullscreenExit": 15,
        "CopyAttempt": 5,
        "PasteAttempt": 10,
        "CutAttempt": 5,
        "ContextMenuAttempt": 3,
        "BlockedShortcut": 5,
        "PossibleDevTools": 25,
        "NetworkDisconnect": 5
      },

      "Levels": {
        "Low": {
          "MinScore": 0,
          "MaxScore": 20
        },
        "Medium": {
          "MinScore": 21,
          "MaxScore": 50
        },
        "High": {
          "MinScore": 51,
          "MaxScore": 80
        },
        "Critical": {
          "MinScore": 81,
          "MaxScore": 999
        }
      }
    },

    "EventLogging": {
      "Enabled": true,
      "BatchEvents": true,
      "BatchSize": 20,
      "FlushIntervalSeconds": 5,
      "FlushOnTabHidden": true,
      "FlushOnBeforeUnload": true,
      "StoreClientTimestamp": true,
      "StoreUserAgent": true,
      "StoreIpAddress": true,
      "StoreQuestionId": true
    }
  }
}
