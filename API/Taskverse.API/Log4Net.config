<?xml version="1.0" encoding="utf-8" ?>
<log4net>

  <!-- ==================== CONSOLE APPENDER (local dev only) ==================== -->
  <appender name="Console" type="log4net.Appender.ColoredConsoleAppender">
    <mapping>
      <level value="ERROR" />
      <foreColor value="Red, HighIntensity" />
    </mapping>
    <mapping>
      <level value="WARN" />
      <foreColor value="Yellow, HighIntensity" />
    </mapping>
    <mapping>
      <level value="INFO" />
      <foreColor value="White" />
    </mapping>
    <mapping>
      <level value="DEBUG" />
      <foreColor value="Cyan" />
    </mapping>
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%date{HH:mm:ss} %-5level %logger{1} - %message%newline%exception" />
    </layout>
  </appender>

  <!-- ==================== GENERAL ROLLING FILE APPENDER ==================== -->
  <appender name="RollingFile" type="log4net.Appender.RollingFileAppender">

    <!-- Linux / server path (commented out — enable on deployment) -->
    <!-- <file type="log4net.Util.PatternString" value="/var/log/Taskverse.Api/Taskverse.Api_%date{yyyy-MM-dd}.log" /> -->

    <!-- Local dev path -->
    <file type="log4net.Util.PatternString" value="C:\Users\Srishty\Downloads\Taskverse\Logs\Taskverse.Api_%date{yyyy-MM-dd}.log" />

    <appendToFile value="true" />
    <rollingStyle value="Composite" />
    <datePattern value="yyyy-MM-dd" />
    <maximumFileSize value="20MB" />
    <maxSizeRollBackups value="10" />
    <staticLogFileName value="false" />
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%date{yyyy-MM-dd HH:mm:ss.fff} [%thread] %-5level %logger - %message%newline%exception" />
    </layout>
    <!-- Exclude IO filter logs — those go to RollingIoFile -->
    <filter type="log4net.Filter.LoggerMatchFilter">
      <loggerToMatch value="Taskverse.IO" />
      <acceptOnMatch value="false" />
    </filter>
  </appender>

  <!-- ==================== IO ROLLING FILE APPENDER ==================== -->
  <appender name="RollingIoFile" type="log4net.Appender.RollingFileAppender">

    <!-- Linux / server path (commented out — enable on deployment) -->
    <!-- <file type="log4net.Util.PatternString" value="/var/log/Taskverse.Api/Taskverse.IO.Api_%date{yyyy-MM-dd}.log" /> -->

    <!-- Local dev path -->
    <file type="log4net.Util.PatternString" value="C:\Users\Srishty\Downloads\Taskverse\Logs\Taskverse.IO.Api_%date{yyyy-MM-dd}.log" />

    <appendToFile value="true" />
    <rollingStyle value="Composite" />
    <datePattern value="yyyy-MM-dd" />
    <maximumFileSize value="20MB" />
    <maxSizeRollBackups value="10" />
    <staticLogFileName value="false" />
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%date{yyyy-MM-dd HH:mm:ss.fff} [%thread] %-5level %logger - %message%newline%exception" />
    </layout>
    <!-- Accept only IO filter logs -->
    <filter type="log4net.Filter.LoggerMatchFilter">
      <loggerToMatch value="Taskverse.IO" />
      <acceptOnMatch value="true" />
    </filter>
    <filter type="log4net.Filter.DenyAllFilter" />
  </appender>

  <root>
    <level value="ALL" />
    <appender-ref ref="Console" />
    <appender-ref ref="RollingFile" />
    <appender-ref ref="RollingIoFile" />
  </root>

</log4net>
