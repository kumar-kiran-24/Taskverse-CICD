[Unit]
Description=Taskverse Users Service
After=network.target

[Service]
WorkingDirectory=/opt/taskverse/users

ExecStart=/usr/bin/dotnet /opt/taskverse/users/Taskverse.API.Users.Service.dll

Restart=always
RestartSec=10

KillSignal=SIGINT

SyslogIdentifier=taskverse-users

User=root

Environment=ASPNETCORE_ENVIRONMENT=Production
Environment=ASPNETCORE_URLS=http://0.0.0.0:5003

[Install]
WantedBy=multi-user.target